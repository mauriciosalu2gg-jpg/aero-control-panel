# Entorno (development / production)
NODE_ENV=development

# ─────────────────────────────────────────────────────────────────────────────
# SEGURIDAD JWT
# OBLIGATORIO en producción. Generar con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ADVERTENCIA: Si pierdes esta clave, TODOS los tokens de sesión actuales
#              quedarán inválidos y los usuarios deberán iniciar sesión de nuevo.
# ─────────────────────────────────────────────────────────────────────────────
JWT_SECRET=CAMBIA_ESTO_genera_con_el_comando_de_arriba
JWT_EXPIRES_IN=24h

# ─────────────────────────────────────────────────────────────────────────────
# CIFRADO DE API KEYS (AES-256-GCM) — Para uso futuro al cifrar keys de IA
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ADVERTENCIA: Si pierdes/rotas esta clave sin migrar los datos cifrados,
#              todas las API Keys guardadas en Firestore quedarán ILEGIBLES.
# Documenta la clave actual antes de rotar. Proceso de rotación:
#   1. Descifrar todos los docs con la clave vieja
#   2. Cambiar ENCRYPTION_KEY
#   3. Re-cifrar todos los docs con la clave nueva
# ─────────────────────────────────────────────────────────────────────────────
ENCRYPTION_KEY=CAMBIA_ESTO_genera_con_el_comando_de_arriba

# Cloudflare Turnstile
# Claves de test (siempre pasan): 1x00000000000000000000AA / 1x000000000000000000000000000000000
TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=1x000000000000000000000000000000000

# Firebase Config (Servicio Administrado)
FIREBASE_PROJECT_ID=aero-panels
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@aero-panels.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvgIBADANBgkqhkiG9w0BAQEFAASCBKgwggSkAgEAAoIBAQC...\n-----END PRIVATE KEY-----\n"

# Límites de Peticiones y Sesiones
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=900000
SESSION_DURATION=86400000
